# API Configuration
# Update these values to point to your backend API gateway or frontend origin.
# The frontend service layer now routes requests to the individual microservices by default.
VITE_API_BASE_URL=http://localhost:5173
VITE_API_TIMEOUT=30000

# Feature Flags
# Keep this disabled for the real microservice-backed app.
VITE_ENABLE_MOCK_DATA=false

# Authentication (for future implementation)
# VITE_ENABLE_AUTH=false

# Third-party Services
# Add keys for services used by backend team
# STRIPE_PUBLIC_KEY=pk_test_...
# GOOGLE_MAPS_API_KEY=...
# FIREBASE_API_KEY=...

# Environment
NODE_ENV=development
